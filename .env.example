# Google Places API (New) – up to 5 public reviews
NEXT_PUBLIC_GOOGLE_PLACE_ID=
NEXT_PUBLIC_GOOGLE_PLACES_API_KEY=

# All reviews: Google Business Profile OAuth (owner access)
# Enable APIs: My Business Account Management, Business Information, Google My Business
# GOOGLE_OAUTH_CLIENT_ID=
# GOOGLE_OAUTH_CLIENT_SECRET=
# GOOGLE_OAUTH_REFRESH_TOKEN=
# Optional if auto-discovery fails:
# GOOGLE_BUSINESS_LOCATION_NAME=accounts/ACCOUNT_ID/locations/LOCATION_ID
# Then run: npm run sync:reviews  →  data/google-reviews-cache.json

# Optional: Google Business Profile share link
# NEXT_PUBLIC_GOOGLE_BUSINESS_URL=

# Google Search Console – HTML tag verification (optional)
# NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
